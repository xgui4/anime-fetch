# Maintainer xgui4 name@example.com
pkgname=anime-fetch
pkgver=nightly
pkgrel=1
pkgdesc="A neofetch-inspired utility that fetch you system info with a OS-Tan"
arch=('x86_64')
url="https://github.com/xgui4/hello-world-gtk"
license=('GPLv3') 
depends=(
  'qt6'
  'bash'
  'chafa'
)
makedepends=(
  'gcc'
  'clang'
  'cmake'
  'git'
)

provides=("${pkgname%-nightly}" "${pkgname%}" "anime-fetch-gui" "anime-fetch-cli" "anime-fetch-lib")
source=("${pkgname}::git+${url}.git#branch=dev")
sha256sums=('SKIP') # will have the check later 

pkgver() {
  cd "$pkgname"
  # cutting off 'foo-' prefix that presents in the git tag
  git describe --long --always --tags | sed 's/^foo-//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd "$pkgname"
}

package() {
  echo "Coming Soon!"
}